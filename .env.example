# DOO slice 1 local-dev environment.
# Copy to `.env` and edit for your setup. Never commit the populated `.env`.

# ----- Neo4j (L3) -----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=doo-dev-password

# ----- Redis (L1 streams + kill-switch lease) -----
REDIS_URL=redis://localhost:6379/0

# ----- MinIO / S3 (request/response bodies) -----
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=doo-dev
S3_SECRET_KEY=doo-dev-password
S3_BUCKET=doo-blobs

# ----- AuthContext tokens (per ADR-0012: env-var references only in YAML) -----
# Populate the actual values here and reference them as ${VAR_NAME} in the
# engagement YAML. Never inline tokens in YAML, ever.
# DOO_BEARER_TOKEN_TEST_USER_A=...

# ----- Logging -----
DOO_LOG_LEVEL=INFO
