{
  "log": {
    "version": "1.2",
    "creator": { "name": "doo-malformed-fixture", "version": "1.0" },
    "comment": "Valid HAR JSON whose entries are individually malformed. The parser must emit ParseFailure events (never raise) and other entries in the same blob must still parse.",
    "entries": [
      {
        "_note": "missing startedDateTime -> ParseFailure(missing_required_field)",
        "request": {
          "method": "GET",
          "url": "https://api.example.com/no-time",
          "headers": [],
          "cookies": [],
          "queryString": []
        },
        "response": { "status": 200, "bodySize": 0 }
      },
      {
        "_note": "missing request object -> ParseFailure(missing_required_field)",
        "startedDateTime": "2026-05-11T12:00:01.000Z",
        "response": { "status": 200, "bodySize": 0 }
      },
      {
        "_note": "relative url (not absolute) -> ParseFailure(schema_mismatch)",
        "startedDateTime": "2026-05-11T12:00:02.000Z",
        "request": {
          "method": "GET",
          "url": "/relative/only",
          "headers": [],
          "cookies": [],
          "queryString": []
        },
        "response": { "status": 200, "bodySize": 0 }
      },
      {
        "_note": "well-formed entry alongside the malformed ones -> RequestObservation",
        "startedDateTime": "2026-05-11T12:00:03.000Z",
        "request": {
          "method": "GET",
          "url": "https://api.example.com/ok",
          "headers": [{ "name": "Host", "value": "api.example.com" }],
          "cookies": [],
          "queryString": []
        },
        "response": { "status": 200, "bodySize": 16 }
      }
    ]
  }
}
